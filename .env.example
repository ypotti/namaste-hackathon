# Create .env from this file and add your key. Never commit .env.
OPENAI_API_KEY=your_openai_api_key_here

# Fallback model parameter
# OPENAI_MODEL=gpt-4o-mini

# Node-specific models
PLANNER_MODEL=gpt-5.5
REVIEWER_MODEL=gpt-5.5-mini
GENERATOR_MODEL=gpt-5.5-mini
# Model used for the visual pre-pass (must support image inputs, e.g. gpt-4o).
REVIEWER_VISION_MODEL=gpt-4o

# ── Visual review via headless browser ────────────────────────────────────────
# Set SCREENSHOT_ENABLED=false to skip the browser screenshot step entirely
# (useful in CI or headless environments without Chromium installed).
SCREENSHOT_ENABLED=true

# Set SCREENSHOT_SAVE=false to capture screenshots for the LLM without
# persisting them to disk.
SCREENSHOT_SAVE=true

# ── LangSmith tracing ─────────────────────────────────────────────────────────
# Get your API key at https://smith.langchain.com → Settings → API Keys
# Set LANGSMITH_TRACING=false to disable tracing without removing the other vars.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=namaste-hackathon
